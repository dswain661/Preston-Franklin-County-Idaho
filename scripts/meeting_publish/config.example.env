# Copy to .env in this folder (never commit .env)

# Fixed Zoom meeting (same every session)
ZOOM_MEETING_ID=123456789
ZOOM_PASSCODE=your_passcode_here

# Where OBS or Zoom saves recordings — watch this folder
RECORDINGS_DIR=C:\Users\You\Videos\meetings\incoming

# Uploaded files moved here
PROCESSED_DIR=C:\Users\You\Videos\meetings\processed

# YouTube OAuth (Google Cloud Console → YouTube Data API v3)
YOUTUBE_CLIENT_SECRETS=client_secrets.json
YOUTUBE_TOKEN_PATH=youtube_token.json

# Video metadata defaults
MEETING_TITLE_PREFIX=Preston City Council
MEETING_DESCRIPTION=Public meeting recording. Official info: https://www.prestonidaho.net/
# public | unlisted | private
YOUTUBE_PRIVACY=unlisted

# Optional: append published URLs to repo manifest (for future meeting hub page)
MANIFEST_PATH=../../data/meetings.json